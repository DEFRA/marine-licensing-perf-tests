<?xml version="1.0" encoding="UTF-8"?>
<jmeterTestPlan version="1.2" properties="5.0" jmeter="5.6.3">
  <hashTree>
    <TestPlan guiclass="TestPlanGui" testclass="TestPlan" testname="Exemption Submission - Manual Coordinate">
      <stringProp name="TestPlan.comments">End-to-end exemption submission via marine-licensing-frontend BFF.
Full happy path: stub login -&gt; project name -&gt; site details (8 sub-pages) -&gt; public register -&gt; declaration submit -&gt; verify EXE reference.
Auth: cdp-defra-id-stub (dev or perf-test once stub is deployed there).</stringProp>
      <boolProp name="TestPlan.functional_mode">false</boolProp>
      <boolProp name="TestPlan.serialize_threadgroups">true</boolProp>
      <elementProp name="TestPlan.user_defined_variables" elementType="Arguments" guiclass="ArgumentsPanel" testclass="Arguments" testname="User Defined Variables">
        <collectionProp name="Arguments.arguments">
          <elementProp name="domain" elementType="Argument">
            <stringProp name="Argument.name">domain</stringProp>
            <stringProp name="Argument.value">${__P(domain,marine-licensing-frontend.dev.cdp-int.defra.cloud)}</stringProp>
          </elementProp>
          <elementProp name="port" elementType="Argument">
            <stringProp name="Argument.name">port</stringProp>
            <stringProp name="Argument.value">${__P(port,443)}</stringProp>
          </elementProp>
          <elementProp name="protocol" elementType="Argument">
            <stringProp name="Argument.name">protocol</stringProp>
            <stringProp name="Argument.value">${__P(protocol,https)}</stringProp>
          </elementProp>
          <elementProp name="stubDomain" elementType="Argument">
            <stringProp name="Argument.name">stubDomain</stringProp>
            <stringProp name="Argument.value">${__P(stubDomain,cdp-defra-id-stub.dev.cdp-int.defra.cloud)}</stringProp>
          </elementProp>
          <elementProp name="stubPort" elementType="Argument">
            <stringProp name="Argument.name">stubPort</stringProp>
            <stringProp name="Argument.value">${__P(stubPort,443)}</stringProp>
          </elementProp>
          <elementProp name="stubProtocol" elementType="Argument">
            <stringProp name="Argument.name">stubProtocol</stringProp>
            <stringProp name="Argument.value">${__P(stubProtocol,https)}</stringProp>
          </elementProp>
          <elementProp name="proxyHost" elementType="Argument">
            <stringProp name="Argument.name">proxyHost</stringProp>
            <stringProp name="Argument.value">${__P(proxyHost,)}</stringProp>
          </elementProp>
          <elementProp name="proxyPort" elementType="Argument">
            <stringProp name="Argument.name">proxyPort</stringProp>
            <stringProp name="Argument.value">${__P(proxyPort,)}</stringProp>
          </elementProp>
          <elementProp name="threads" elementType="Argument">
            <stringProp name="Argument.name">threads</stringProp>
            <stringProp name="Argument.value">${__P(threads,3)}</stringProp>
          </elementProp>
          <elementProp name="rampSeconds" elementType="Argument">
            <stringProp name="Argument.name">rampSeconds</stringProp>
            <stringProp name="Argument.value">${__P(rampSeconds,30)}</stringProp>
          </elementProp>
          <elementProp name="loops" elementType="Argument">
            <stringProp name="Argument.name">loops</stringProp>
            <stringProp name="Argument.value">${__P(loops,5)}</stringProp>
          </elementProp>
          <elementProp name="thinkTimeMs" elementType="Argument">
            <stringProp name="Argument.name">thinkTimeMs</stringProp>
            <stringProp name="Argument.value">${__P(thinkTimeMs,500)}</stringProp>
          </elementProp>
          <elementProp name="journeyVariant" elementType="Argument">
            <stringProp name="Argument.name">journeyVariant</stringProp>
            <stringProp name="Argument.value">${__P(journey,dev)}</stringProp>
            <stringProp name="Argument.desc">dev (legacy UI: project-name -&gt; how-do-you-want-to-provide directly) or perftest (newer UI: project-name -&gt; task-list hub, review-site-details + cya intermediates).</stringProp>
          </elementProp>
        </collectionProp>
      </elementProp>
    </TestPlan>
    <hashTree>
      <ConfigTestElement guiclass="HttpDefaultsGui" testclass="ConfigTestElement" testname="HTTP Request Defaults">
        <stringProp name="HTTPSampler.domain">${domain}</stringProp>
        <stringProp name="HTTPSampler.port">${port}</stringProp>
        <stringProp name="HTTPSampler.protocol">${protocol}</stringProp>
        <stringProp name="HTTPSampler.proxyHost">${proxyHost}</stringProp>
        <stringProp name="HTTPSampler.proxyPort">${proxyPort}</stringProp>
        <stringProp name="HTTPSampler.connect_timeout">10000</stringProp>
        <stringProp name="HTTPSampler.response_timeout">60000</stringProp>
        <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
        <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
        <stringProp name="HTTPSampler.implementation">HttpClient4</stringProp>
        <elementProp name="HTTPsampler.Arguments" elementType="Arguments" guiclass="HTTPArgumentsPanel" testclass="Arguments">
          <collectionProp name="Arguments.arguments"/>
        </elementProp>
      </ConfigTestElement>
      <hashTree/>
      <HeaderManager guiclass="HeaderPanel" testclass="HeaderManager" testname="HTTP Headers">
        <collectionProp name="HeaderManager.headers">
          <elementProp name="" elementType="Header">
            <stringProp name="Header.name">Accept</stringProp>
            <stringProp name="Header.value">text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8</stringProp>
          </elementProp>
          <elementProp name="" elementType="Header">
            <stringProp name="Header.name">Accept-Language</stringProp>
            <stringProp name="Header.value">en-GB,en;q=0.9</stringProp>
          </elementProp>
          <elementProp name="" elementType="Header">
            <stringProp name="Header.name">User-Agent</stringProp>
            <stringProp name="Header.value">Mozilla/5.0 (jmeter-perf-test exemption-submission)</stringProp>
          </elementProp>
        </collectionProp>
      </HeaderManager>
      <hashTree/>
      <CookieManager guiclass="CookiePanel" testclass="CookieManager" testname="HTTP Cookies">
        <boolProp name="CookieManager.clearEachIteration">false</boolProp>
        <stringProp name="CookieManager.policy">standard</stringProp>
        <boolProp name="CookieManager.controlledByThreadGroup">true</boolProp>
      </CookieManager>
      <hashTree/>
      <CacheManager guiclass="CacheManagerGui" testclass="CacheManager" testname="HTTP Cache">
        <boolProp name="clearEachIteration">true</boolProp>
        <boolProp name="useExpires">true</boolProp>
      </CacheManager>
      <hashTree/>

      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup" testname="Exemption Submission Flow">
        <stringProp name="ThreadGroup.num_threads">${threads}</stringProp>
        <stringProp name="ThreadGroup.ramp_time">${rampSeconds}</stringProp>
        <boolProp name="ThreadGroup.same_user_on_next_iteration">true</boolProp>
        <stringProp name="ThreadGroup.on_sample_error">continue</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController" guiclass="LoopControlPanel" testclass="LoopController">
          <stringProp name="LoopController.loops">${loops}</stringProp>
          <boolProp name="LoopController.continue_forever">false</boolProp>
        </elementProp>
      </ThreadGroup>
      <hashTree>
        <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Per-iteration test data">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.time.LocalDate
def runId = UUID.randomUUID().toString().take(8)
vars.put('runId', runId)
vars.put('projectName', "Perf Exemption ${runId}")
def today = LocalDate.now()
def start = today.plusDays(60)
def end = today.plusDays(180)
vars.put('startDay', String.format('%02d', start.getDayOfMonth()))
vars.put('startMonth', String.format('%02d', start.getMonthValue()))
vars.put('startYear', String.valueOf(start.getYear()))
vars.put('endDay', String.format('%02d', end.getDayOfMonth()))
vars.put('endMonth', String.format('%02d', end.getMonthValue()))
vars.put('endYear', String.valueOf(end.getYear()))
</stringProp>
        </JSR223PreProcessor>
        <hashTree/>

        <OnceOnlyController guiclass="OnceOnlyControllerGui" testclass="OnceOnlyController" testname="Login (once per VU)"/>
        <hashTree>
          <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Generate per-VU user data">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">def uniq = UUID.randomUUID().toString().take(8)
vars.put('userEmail', "perf-${uniq}@example.com")
vars.put('userFirstName', 'Perf')
vars.put('userLastName', "Test ${uniq}")
SampleResult.setResponseData("userEmail=${vars.get('userEmail')}", 'UTF-8')
SampleResult.setResponseMessage('user data set')
</stringProp>
          </JSR223Sampler>
          <hashTree/>

          <TransactionController guiclass="TransactionControllerGui" testclass="TransactionController" testname="TX-LOGIN">
            <boolProp name="TransactionController.parent">false</boolProp>
          </TransactionController>
          <hashTree>
            <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="POST stub register user">
              <stringProp name="HTTPSampler.domain">${stubDomain}</stringProp>
              <stringProp name="HTTPSampler.port">${stubPort}</stringProp>
              <stringProp name="HTTPSampler.protocol">${stubProtocol}</stringProp>
              <stringProp name="HTTPSampler.path">/cdp-defra-id-stub/API/register</stringProp>
              <stringProp name="HTTPSampler.method">POST</stringProp>
              <boolProp name="HTTPSampler.postBodyRaw">true</boolProp>
              <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
                <collectionProp name="Arguments.arguments">
                  <elementProp name="" elementType="HTTPArgument">
                    <boolProp name="HTTPArgument.always_encode">false</boolProp>
                    <stringProp name="Argument.value">{"email":"${userEmail}","firstName":"${userFirstName}","lastName":"${userLastName}","loa":"1","aal":"1","enrolmentCount":1,"enrolmentRequestCount":1,"relationships":[]}</stringProp>
                    <stringProp name="Argument.metadata">=</stringProp>
                  </elementProp>
                </collectionProp>
              </elementProp>
            </HTTPSamplerProxy>
            <hashTree>
              <HeaderManager guiclass="HeaderPanel" testclass="HeaderManager" testname="JSON Content-Type">
                <collectionProp name="HeaderManager.headers">
                  <elementProp name="" elementType="Header">
                    <stringProp name="Header.name">Content-Type</stringProp>
                    <stringProp name="Header.value">application/json</stringProp>
                  </elementProp>
                </collectionProp>
              </HeaderManager>
              <hashTree/>
              <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion" testname="201 Created">
                <collectionProp name="Asserion.test_strings">
                  <stringProp name="49587">201</stringProp>
                </collectionProp>
                <stringProp name="Assertion.test_field">Assertion.response_code</stringProp>
                <intProp name="Assertion.test_type">8</intProp>
              </ResponseAssertion>
              <hashTree/>
              <JSONPostProcessor guiclass="JSONPostProcessorGui" testclass="JSONPostProcessor" testname="Extract userId from register response">
                <stringProp name="JSONPostProcessor.referenceNames">userId</stringProp>
                <stringProp name="JSONPostProcessor.jsonPathExprs">$.userId</stringProp>
                <stringProp name="JSONPostProcessor.match_numbers">1</stringProp>
                <stringProp name="JSONPostProcessor.defaultValues">NO_USER_ID</stringProp>
              </JSONPostProcessor>
              <hashTree/>
            </hashTree>

            <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="GET /exemption (IAT entry) -> stub picker">
              <stringProp name="HTTPSampler.path">/exemption?ADV_TYPE=EXE&amp;ARTICLE=17&amp;ACTIVITY_TYPE=DEPOSIT&amp;outcomeType=WO_EXE_AVAILABLE_ARTICLE_17</stringProp>
              <stringProp name="HTTPSampler.method">GET</stringProp>
              <boolProp name="HTTPSampler.postBodyRaw">false</boolProp>
              <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
                <collectionProp name="Arguments.arguments"/>
              </elementProp>
            </HTTPSamplerProxy>
            <hashTree>
              <RegexExtractor guiclass="RegexExtractorGui" testclass="RegexExtractor" testname="Extract all stub login links">
                <stringProp name="RegexExtractor.useHeaders">false</stringProp>
                <stringProp name="RegexExtractor.refname">allLoginPaths</stringProp>
                <stringProp name="RegexExtractor.regex">href=&quot;(/cdp-defra-id-stub/authorize[^&quot;]+user=[^&quot;]+)&quot;</stringProp>
                <stringProp name="RegexExtractor.template">$1$</stringProp>
                <stringProp name="RegexExtractor.default">NO_LOGIN_LINK</stringProp>
                <stringProp name="RegexExtractor.match_number">-1</stringProp>
              </RegexExtractor>
              <hashTree/>
              <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Pick login link for our email">
                <stringProp name="scriptLanguage">groovy</stringProp>
                <stringProp name="parameters"></stringProp>
                <stringProp name="filename"></stringProp>
                <stringProp name="cacheKey">true</stringProp>
                <stringProp name="script">def myEmail = vars.get('userEmail')
def count = (vars.get('allLoginPaths_matchNr') ?: '0') as int
def found = 'NO_LOGIN_LINK'
for (int i = 1; i &lt;= count; i++) {
  def link = vars.get("allLoginPaths_${i}")
  if (link &amp;&amp; link.contains(myEmail)) { found = link; break }
}
vars.put('stubLoginPath', found)
</stringProp>
              </JSR223PostProcessor>
              <hashTree/>
            </hashTree>

            <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="GET stub login link -> /confirm-individual">
              <stringProp name="HTTPSampler.domain">${stubDomain}</stringProp>
              <stringProp name="HTTPSampler.port">${stubPort}</stringProp>
              <stringProp name="HTTPSampler.protocol">${stubProtocol}</stringProp>
              <stringProp name="HTTPSampler.path">${stubLoginPath}</stringProp>
              <stringProp name="HTTPSampler.method">GET</stringProp>
              <boolProp name="HTTPSampler.postBodyRaw">false</boolProp>
              <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
                <collectionProp name="Arguments.arguments"/>
              </elementProp>
            </HTTPSamplerProxy>
            <hashTree>
              <RegexExtractor guiclass="RegexExtractorGui" testclass="RegexExtractor" testname="Extract csrfToken">
                <stringProp name="RegexExtractor.useHeaders">false</stringProp>
                <stringProp name="RegexExtractor.refname">csrfToken</stringProp>
                <stringProp name="RegexExtractor.regex">name=&quot;csrfToken&quot;[^&gt;]*value=&quot;([^&quot;]+)&quot;</stringProp>
                <stringProp name="RegexExtractor.template">$1$</stringProp>
                <stringProp name="RegexExtractor.default">NO_CSRF</stringProp>
                <stringProp name="RegexExtractor.match_number">-1</stringProp>
              </RegexExtractor>
              <hashTree/>
              <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Pick last csrfToken">
                <stringProp name="scriptLanguage">groovy</stringProp>
                <stringProp name="parameters"></stringProp>
                <stringProp name="filename"></stringProp>
                <stringProp name="cacheKey">true</stringProp>
                <stringProp name="script">def n = (vars.get('csrfToken_matchNr') ?: '0') as int
if (n &gt; 0) vars.put('csrfToken', vars.get("csrfToken_${n}"))
</stringProp>
              </JSR223PostProcessor>
              <hashTree/>
            </hashTree>

            <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="POST /confirm-individual (yes)">
              <stringProp name="HTTPSampler.path">/confirm-individual</stringProp>
              <stringProp name="HTTPSampler.method">POST</stringProp>
              <boolProp name="HTTPSampler.postBodyRaw">false</boolProp>
              <stringProp name="HTTPSampler.contentEncoding">UTF-8</stringProp>
              <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
