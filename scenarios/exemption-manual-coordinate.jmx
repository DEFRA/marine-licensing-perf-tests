if (n &gt; 0) vars.put('csrfToken', vars.get("csrfToken_${n}"))
</stringProp>
                </JSR223PostProcessor>
                <hashTree/>
              </hashTree>
            </hashTree>
          </hashTree>
        </hashTree>

        <ConstantTimer guiclass="ConstantTimerGui" testclass="ConstantTimer" testname="Think">
          <stringProp name="ConstantTimer.delay">${thinkTimeMs}</stringProp>
        </ConstantTimer>
        <hashTree/>

