              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="script">def url = prev.getUrlAsString() ?: ''
def ready = url.contains('/exemption/activity-dates') ||
            url.contains('/exemption/same-activity-') ||
            url.contains('/exemption/site-name') ||
            url.contains('/exemption/review-site-details')
vars.put('uploadReady', ready ? 'true' : 'false')
log.info("POLL1 url=${url.take(120)} ready=${ready}")
</stringProp>
            </JSR223PostProcessor>
            <hashTree/>
          </hashTree>
          <WhileController guiclass="WhileControllerGui" testclass="WhileController" testname="while !uploadReady">
            <stringProp name="WhileController.condition">${__groovy(vars.get('uploadReady') != 'true' &amp;&amp; (vars.get('pollCount') ?: '0') as int &lt; 15)}</stringProp>
          </WhileController>
          <hashTree>
            <ConstantTimer guiclass="ConstantTimerGui" testclass="ConstantTimer" testname="Wait 3s">
              <stringProp name="ConstantTimer.delay">3000</stringProp>
            </ConstantTimer>
            <hashTree/>
            <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="GET /exemption/upload-and-wait (poll N)">
              <stringProp name="HTTPSampler.path">/exemption/upload-and-wait</stringProp>
              <stringProp name="HTTPSampler.method">GET</stringProp>
              <boolProp name="HTTPSampler.postBodyRaw">false</boolProp>
              <stringProp name="HTTPSampler.response_timeout">15000</stringProp>
              <elementProp name="HTTPsampler.Arguments" elementType="Arguments"><collectionProp name="Arguments.arguments"/></elementProp>
            </HTTPSamplerProxy>
            <hashTree>
              <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Check ready / increment counter">
                <stringProp name="scriptLanguage">groovy</stringProp>
                <stringProp name="parameters"></stringProp>
                <stringProp name="filename"></stringProp>
                <stringProp name="cacheKey">true</stringProp>
                <stringProp name="script">def url = prev.getUrlAsString() ?: ''
def ready = url.contains('/exemption/activity-dates') ||
            url.contains('/exemption/same-activity-') ||
            url.contains('/exemption/site-name') ||
            url.contains('/exemption/review-site-details')
vars.put('uploadReady', ready ? 'true' : 'false')
def n = ((vars.get('pollCount') ?: '0') as int) + 1
vars.put('pollCount', String.valueOf(n))
def body = prev.getResponseDataAsString() ?: ''
def csrfMatches = (body =~ /name="csrfToken"[^&gt;]*value="([^"]+)"/).collect{it[1]}
if (csrfMatches) vars.put('csrfToken', csrfMatches[-1])
log.info("POLL${n} url=${url.take(120)} ready=${ready}")
</stringProp>
              </JSR223PostProcessor>
              <hashTree/>
            </hashTree>
          </hashTree>
          <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Reset pollCount + assert ready">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">def ready = vars.get('uploadReady') == 'true'
def polls = vars.get('pollCount') ?: '0'
SampleResult.setResponseData("uploadReady=${ready} polls=${polls}", 'UTF-8')
SampleResult.setResponseCode(ready ? '200' : '500')
SampleResult.setResponseMessage(ready ? 'ready' : 'not ready after polls')
SampleResult.setSuccessful(ready)
vars.put('pollCount', '0')
vars.put('uploadReady', 'false')
</stringProp>
          </JSR223Sampler>
          <hashTree/>
