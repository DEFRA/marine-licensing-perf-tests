        <hashTree/>
        <TransactionController guiclass="TransactionControllerGui" testclass="TransactionController" testname="TX-05 Upload KML file">
          <boolProp name="TransactionController.parent">false</boolProp>
        </TransactionController>
        <hashTree>
          <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Upload KML via Apache HttpClient">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import org.apache.jmeter.protocol.http.control.CookieManager
import org.apache.jmeter.protocol.http.control.Cookie

def domain = vars.get('domain')
def protocol = vars.get('protocol')
def port = vars.get('port')
def uploadPath = vars.get('uploadUrl')
def kmlPath = vars.get('kmlPath')

if (!uploadPath || uploadPath == 'NO_UPLOAD_URL') {
    SampleResult.setSuccessful(false)
    SampleResult.setResponseCode('NO_UPLOAD_URL')
    SampleResult.setResponseMessage('uploadUrl was not extracted from previous sampler')
    return
}

def portSuffix = (port == '443' || port == '80' || !port) ? '' : ":${port}"
def fullUrl = uploadPath.startsWith('http://') || uploadPath.startsWith('https://')
    ? uploadPath
    : "${protocol}://${domain}${portSuffix}${uploadPath}"
// Local docker: rewrite internal docker hostnames to localhost+host-mapped port
def uploaderRewrite = props.get('uploaderRewrite') ?: System.getenv('UPLOADER_REWRITE')
if (uploaderRewrite) {
    def pair = uploaderRewrite.split('=')
    if (pair.length == 2) fullUrl = fullUrl.replace(pair[0], pair[1])
}
def referer = "${protocol}://${domain}${portSuffix}/exemption/upload-file"

// Pull cookies from the previous sampler's request headers (JMeter's CookieManager stamped them)
def cookieHeader = ''
def lastSample = prev
if (lastSample) {
    def reqHeaders = lastSample.getRequestHeaders() ?: ''
    def cookieMatch = (reqHeaders =~ /(?im)^Cookie:\s*([^\r\n]+)/)
    if (cookieMatch) {
        cookieHeader = cookieMatch[0][1]
    }
}

def fileToUpload = new File(kmlPath)
if (!fileToUpload.exists()) {
    SampleResult.setSuccessful(false)
    SampleResult.setResponseCode('FILE_NOT_FOUND')
    SampleResult.setResponseMessage("KML file not found: ${kmlPath}")
    return
}

List&lt;String&gt; cmd = new ArrayList&lt;&gt;()
cmd.add('curl'); cmd.add('-s')
cmd.add('-X'); cmd.add('POST')
cmd.add('-F'); cmd.add(("file=@" + kmlPath + ";type=application/vnd.google-earth.kml+xml").toString())
cmd.add('-H'); cmd.add(("Referer: " + referer).toString())
cmd.add('-H'); cmd.add(("Origin: " + protocol + "://" + domain + portSuffix).toString())
cmd.add('-A'); cmd.add('Mozilla/5.0 (jmeter-perf-test exemption-file-upload)')
cmd.add('-w')
cmd.add('---JMETER_META---%{http_code}|%{url_effective}')
if (cookieHeader) {
    cmd.add('-H')
    cmd.add(("Cookie: " + cookieHeader).toString())
}
cmd.add(fullUrl.toString())

SampleResult.sampleStart()
SampleResult.setURL(new java.net.URL(fullUrl))
SampleResult.setSentBytes(fileToUpload.length())

try {
    def proc = new ProcessBuilder(cmd).redirectErrorStream(true).start()
    def output = proc.inputStream.text
    def exitCode = proc.waitFor()
    
    def metaIdx = output.lastIndexOf('---JMETER_META---')
    def body = metaIdx &gt;= 0 ? output.substring(0, metaIdx) : output
    def meta = metaIdx &gt;= 0 ? output.substring(metaIdx + '---JMETER_META---'.length()).trim() : ''
    def pipeIdx = meta.indexOf('|')
    def code = pipeIdx &gt;= 0 ? meta.substring(0, pipeIdx).trim() : meta.trim()
    def finalUrl = pipeIdx &gt;= 0 ? meta.substring(pipeIdx + 1).trim() : fullUrl
    
    SampleResult.setResponseCode(code)
    SampleResult.setResponseMessage(exitCode == 0 ? 'OK' : "curl exit ${exitCode}")
    SampleResult.setResponseData(body, 'UTF-8')
    SampleResult.setBodySize((long) body.bytes.length)
    try { SampleResult.setURL(new java.net.URL(finalUrl)) } catch (Exception ignore) {}
    SampleResult.setSuccessful(exitCode == 0 &amp;&amp; (code.startsWith('2') || code.startsWith('3')))
    log.info("CURL_UPLOAD code=${code} exit=${exitCode} final=${finalUrl}")
} catch (Exception e) {
    SampleResult.setSuccessful(false)
    SampleResult.setResponseCode('EXCEPTION')
    SampleResult.setResponseMessage(e.message)
    log.warn("CURL_UPLOAD failed: ${e.message}")
} finally {
    SampleResult.sampleEnd()
}
</stringProp>
          </JSR223Sampler>
          <hashTree>
            <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion" testname="2xx/3xx">
