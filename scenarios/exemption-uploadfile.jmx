if (n &gt; 0) vars.put('csrfToken', vars.get("csrfToken_${n}"))
</stringProp>
            </JSR223PostProcessor>
            <hashTree/>
            <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion" testname="200">
              <collectionProp name="Asserion.test_strings">
                <stringProp name="49586">200</stringProp>
